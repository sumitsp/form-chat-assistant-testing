QDRANT_URL=http://187.77.186.41:6333
# Optional: if set, chat.py uses OpenAI for answers (model below). Otherwise answers are retrieval-only from snippets.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
# Qdrant vectors (must match ingest): OpenAI text-embedding-3-small = 1536
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_SIZE=1536
# If empty/omitted, the frontend uses same-origin `/api/*` (recommended with Vite proxy / reverse proxy).
# VITE_API_BASE_URL=

# MySQL — used by the eligibility engine (Track A structured database)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=newpoint_mortgage

# Logging / diagnostics (optional — values shown are the defaults)
LOG_LEVEL=INFO
# Log every /api/* request + response body to the terminal. Handy in dev, but it
# writes borrower data (PII) to the log — set to 0 in any shared/production env.
LOG_API_IO=1
# Write /api/* request + response payloads to logs/api_io_*.json (full bodies, not truncated).
LOG_API_IO_FILE=0
LOG_API_IO_FILE_KEEP=50
# Write per-program eligibility trace files to logs/*.txt (debug only; OFF by default).
ELIGIBILITY_TRACE=0
# When trace files are on, keep only the most recent N.
ELIGIBILITY_TRACE_KEEP=50

# LoanPASS Public API pricing (Check pricing) — https://docs.loanpass.io/public-api/
# Login: https://app.loanpass.io/login/newpoint — client id defaults to "newpoint"
LOANPASS_ORIGIN=https://app.loanpass.io
LOANPASS_CLIENT_ACCESS_ID=newpoint
LOANPASS_EMAIL=
LOANPASS_PASSWORD=
# Write LoanPASS request/response payloads to logs/loanpass_pricing_*.json (verify API hits).
LOANPASS_PRICING_LOG=0
LOANPASS_PRICING_LOG_KEEP=50
# Lock period sent to LoanPASS and shown in the pricing grid (days).
LOANPASS_FOCUS_LOCK_DAYS=30
# Pricing runs as its own service (backend/pricing_app.py) so LoanPASS can be
# restarted without bouncing the main API. Set to 1 to ALSO serve /api/loanpass/*
# from backend.api (single-process dev). Leave blank/0 to keep them separate.
MOUNT_PRICING_INLINE=

# Web UI: run API, pricing service, then frontend (three terminals, repo root):
#   python -m uvicorn backend.api:app --reload --host 127.0.0.1 --port 8080      (or: npm run dev:api)
#   python -m uvicorn backend.pricing_app:app --reload --host 127.0.0.1 --port 8090   (or: npm run dev:pricing)
#   npm run dev
# Frontend env (frontend/.env, optional): point pricing at a separate host in prod.
#   VITE_PRICING_BASE_URL=https://pricing.example.com
# Dev Vite proxy target for /api/loanpass (defaults to http://127.0.0.1:8090):
#   VITE_PRICING_PROXY_TARGET=http://127.0.0.1:8090

# One-time setup (see ingest/README.md):
#   mysql -u root -p newpoint_mortgage < ingest/schema.sql
#   python ingest/lenders/denali_flow_to_mysql_qdrant.py --apply
#   python ingest/lenders/denali_nqm_guidelines_qdrant.py --apply

